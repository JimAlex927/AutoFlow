<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#32467D"
                android:centerColor="#263A63"
                android:endColor="#1D2E4E" />
            <stroke
                android:width="1dp"
                android:color="#66CBE3FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#4C66A7"
                android:centerColor="#35518A"
                android:endColor="#253B63" />
            <stroke
                android:width="1dp"
                android:color="#8AD8EBFF" />
        </shape>
    </item>
</selector>

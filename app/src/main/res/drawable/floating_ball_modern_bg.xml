<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#2D3C6E"
                android:endColor="#233455" />
            <stroke
                android:width="1dp"
                android:color="#55BFD6FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#3D4F86"
                android:endColor="#2B3F6A" />
            <stroke
                android:width="1dp"
                android:color="#77D2E6FF" />
        </shape>
    </item>
</selector>

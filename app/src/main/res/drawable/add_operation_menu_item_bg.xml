<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <corners android:radius="12dp" />
            <solid android:color="@color/addOperationMenuSurfaceSelected" />
            <stroke
                android:width="1dp"
                android:color="@color/colorPrimaryLight" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="12dp" />
            <solid android:color="@color/addOperationMenuSurfacePressed" />
            <stroke
                android:width="1dp"
                android:color="@color/addOperationMenuOutlineStrong" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="12dp" />
            <solid android:color="@color/addOperationMenuSurfaceAlt" />
            <stroke
                android:width="1dp"
                android:color="@color/addOperationMenuOutline" />
        </shape>
    </item>
</selector>

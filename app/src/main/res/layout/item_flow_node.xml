<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="8dp"
    android:background="@drawable/item_operation_compact_bg">

    <View
        android:id="@+id/flow_indicator"
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:background="#4caf50" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="10dp">

    <TextView
        android:id="@+id/tv_flow_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#243446"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_flow_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="11sp"
        android:textColor="#6a7682"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_flow_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:textSize="11sp"
        android:textColor="#2f4f7c" />

        <TextView
            android:id="@+id/tv_flow_fallback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="11sp"
            android:textColor="#b23b3b" />

    </LinearLayout>

</LinearLayout>

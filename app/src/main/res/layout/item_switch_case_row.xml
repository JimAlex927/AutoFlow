<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="8dp"
    android:padding="8dp"
    android:background="@drawable/item_operation_compact_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="case "
            android:textSize="13sp"
            android:textColor="#4e5f74"/>

        <EditText
            android:id="@+id/edt_case_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="匹配值，例如: success"
            android:textSize="13sp"
            android:layout_marginStart="4dp"/>

        <TextView
            android:id="@+id/btn_delete_case"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#B23B3B"
            android:background="@drawable/item_operation_compact_bg"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="→ "
            android:textSize="13sp"
            android:textColor="#4e5f74"/>

        <AutoCompleteTextView
            android:id="@+id/edt_case_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="跳转节点ID"
            android:textSize="13sp"
            android:layout_marginStart="4dp"/>

        <TextView
            android:id="@+id/btn_pick_case_next"
            android:layout_width="58dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="选择"
            android:textSize="12sp"
            android:textColor="#315dbf"
            android:background="@drawable/item_operation_compact_bg"/>
    </LinearLayout>
</LinearLayout>

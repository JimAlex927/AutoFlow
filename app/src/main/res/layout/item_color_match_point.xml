<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/item_operation_compact_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_point_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="采样点"
            android:textColor="@color/colorOnSurface"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_remove_point"
            android:layout_width="52dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="删除"
            android:textColor="@color/colorError"
            android:background="@drawable/project_panel_btn_minor" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:text="坐标 (x,y)"
        android:textColor="@color/colorOnSurfaceVariant"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/edt_point_xy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="120,340"
            android:singleLine="true" />

        <TextView
            android:id="@+id/btn_pick_color_point"
            android:layout_width="68dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="取色"
            android:textColor="@color/colorPrimary"
            android:background="@drawable/item_operation_compact_bg" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:text="目标颜色"
        android:textColor="@color/colorOnSurfaceVariant"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/edt_point_color"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="#A1B2C3"
            android:singleLine="true" />

        <View
            android:id="@+id/view_point_color_preview"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/edit_text_background" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:text="容差 (RGB 每通道)"
        android:textColor="@color/colorOnSurfaceVariant"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/edt_point_tolerance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="12"
        android:inputType="number"
        android:singleLine="true" />

</LinearLayout>

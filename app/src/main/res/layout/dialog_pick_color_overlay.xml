<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#33000000">

    <com.auto.master.auto.ColorPointPickerView
        android:id="@+id/color_picker_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/pick_color_floating_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/panel_background"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/view_pick_color_preview"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/edit_text_background" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_pick_color_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#FFFFFF"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_pick_color_coord"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="x=0, y=0"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_pick_color_cancel"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/btn_cancel_bg"
                android:gravity="center"
                android:minWidth="56dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="取消"
                android:textColor="#33455C"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_pick_color_confirm"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/btn_edit_selector"
                android:gravity="center"
                android:minWidth="56dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="确定"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>

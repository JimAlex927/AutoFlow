<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/item_operation_compact_bg"
    android:padding="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="80dp">

        <ImageView
            android:id="@+id/iv_template_item"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="模板图片" />

        <CheckBox
            android:id="@+id/chk_template_pick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:buttonTint="#315dbf"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_template_delete"
            android:layout_width="34dp"
            android:layout_height="24dp"
            android:layout_gravity="top|start"
            android:gravity="center"
            android:text="删"
            android:textSize="10sp"
            android:textColor="#b23b3b"
            android:background="@drawable/item_operation_compact_bg"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_template_item_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="11sp"
        android:textColor="#4e5f74"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_template_item_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#7a8794"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/project_panel_row_bg"
    android:minHeight="60dp"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <ImageView
        android:id="@+id/folder_icon"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_centerVertical="true"
        android:background="@drawable/project_panel_icon_chip"
        android:padding="8dp"
        android:src="@drawable/ic_folder_colored" />

    <ImageView
        android:id="@+id/edit_icon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@id/more_options"
        android:layout_marginEnd="4dp"
        android:background="@drawable/project_panel_toolbar_icon_bg"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_edit"
        android:tint="#728090"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/more_options"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="@drawable/project_panel_toolbar_icon_bg"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_more"
        android:tint="#728090"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@id/folder_icon"
        android:layout_toStartOf="@id/edit_icon"
        android:orientation="vertical">

        <TextView
            android:id="@+id/folder_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#253244"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/folder_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#7B8795"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

</RelativeLayout>

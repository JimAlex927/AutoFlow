<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/dialog_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="运行前自检"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#315dbf"
        android:gravity="center" />

    <TextView
        android:id="@+id/tv_precheck_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:padding="10dp"
        android:textColor="#2d3d4f"
        android:textSize="12sp"
        android:lineSpacingExtra="2dp"
        android:background="@drawable/item_operation_compact_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_precheck_fix"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="去修复"
            android:textColor="#315dbf"
            android:background="@drawable/item_operation_compact_bg"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btn_precheck_continue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="仍然运行"
            android:textColor="#b23b3b"
            android:background="@drawable/item_operation_compact_bg"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_precheck_cancel"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="取消"
        android:textColor="#6a7682"
        android:background="@drawable/item_operation_compact_bg" />

</LinearLayout>

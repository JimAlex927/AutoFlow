<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/dialog_background">

    <!-- 拖动标题栏 -->
    <LinearLayout
        android:id="@+id/dialog_drag_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HTTP 请求节点"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#00838F"/>

        <TextView
            android:id="@+id/btn_scale_dialog"
            android:layout_width="44dp"
            android:layout_height="30dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="放大"
            android:textSize="11sp"
            android:textColor="#315dbf"
            android:background="@drawable/item_operation_compact_bg" />

        <TextView
            android:id="@+id/btn_close_top"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="✕"
            android:textStyle="bold"
            android:textColor="#5f6f84"
            android:background="@drawable/item_operation_compact_bg" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="发送 HTTP 请求，将响应体、状态码存入指定变量，支持 ${变量名} 模板替换"
                android:textSize="12sp"
                android:textColor="#6a7682"
                android:layout_marginBottom="10dp"/>

            <!-- 操作名称 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="操作名称"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="例如: 登录接口请求"
                android:layout_marginBottom="12dp"/>

            <!-- 请求 URL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请求 URL"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="https://api.example.com/path?key=${apiKey}"
                android:inputType="textUri"
                android:singleLine="true"
                android:layout_marginBottom="12dp"/>

            <!-- 请求方法 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请求方法"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinner_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <!-- 请求头 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请求头（每行 Key: Value，支持 ${变量名}，可选）"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_headers"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:hint="Content-Type: application/json&#10;Authorization: Bearer ${token}"
                android:layout_marginBottom="12dp"/>

            <!-- 请求体（POST/PUT/PATCH/DELETE 显示） -->
            <TextView
                android:id="@+id/tv_body_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请求体（支持 ${变量名}，可选）"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_body"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:hint="{&quot;username&quot;: &quot;${user}&quot;, &quot;password&quot;: &quot;${pass}&quot;}"
                android:layout_marginBottom="12dp"/>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="响应处理"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#00838F"
                android:layout_marginBottom="8dp"/>

            <!-- 响应体存入变量 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="响应体存入变量（可选，如: res）"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_response_var"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="res"
                android:singleLine="true"
                android:layout_marginBottom="12dp"/>

            <!-- 状态码存入变量 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="状态码存入变量（可选，如: http_status）"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_status_var"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="http_status"
                android:singleLine="true"
                android:layout_marginBottom="12dp"/>

            <!-- 超时 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="超时时间（毫秒，默认 10000）"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_timeout_ms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:hint="10000"
                android:singleLine="true"
                android:layout_marginBottom="12dp"/>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="路由配置"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#00838F"
                android:layout_marginBottom="8dp"/>

            <!-- 成功后节点 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="成功（2xx）后节点（可选）"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <AutoCompleteTextView
                    android:id="@+id/edt_next_operation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="例如: op_002"/>

                <TextView
                    android:id="@+id/btn_pick_next"
                    android:layout_width="58dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="选择"
                    android:textColor="#315dbf"
                    android:background="@drawable/item_operation_compact_bg"/>
            </LinearLayout>

            <!-- 失败后节点 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="失败 / 网络错误后节点（可选）"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <AutoCompleteTextView
                    android:id="@+id/edt_fallback_operation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="例如: op_error_handler"/>

                <TextView
                    android:id="@+id/btn_pick_fallback"
                    android:layout_width="58dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="选择"
                    android:textColor="#315dbf"
                    android:background="@drawable/item_operation_compact_bg"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="取消"
            android:textColor="#666666"
            android:background="@drawable/btn_cancel_bg"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="确认添加"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_edit_selector"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_variable_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="变量名"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_variable_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="String"
            android:textColor="#9C27B0"
            android:textSize="11sp"
            android:background="#3D2D4D"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

        <View
            android:id="@+id/indicator_changed"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="8dp"
            android:background="@android:drawable/presence_online"
            android:backgroundTint="#FF9800"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_variable_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="值"
        android:textColor="#4CAF50"
        android:textSize="13sp"
        android:maxLines="3"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_variable_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="历史: 3次变化"
        android:textColor="#666666"
        android:textSize="11sp" />

</LinearLayout>

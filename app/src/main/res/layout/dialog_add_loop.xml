<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/dialog_background">

    <LinearLayout
        android:id="@+id/dialog_drag_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="二分路节点"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#315dbf"/>

        <TextView
            android:id="@+id/btn_scale_dialog"
            android:layout_width="44dp"
            android:layout_height="30dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="放大"
            android:textSize="11sp"
            android:textColor="#315dbf"
            android:background="@drawable/item_operation_compact_bg" />

        <TextView
            android:id="@+id/btn_close_top"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="✕"
            android:textStyle="bold"
            android:textColor="#5f6f84"
            android:background="@drawable/item_operation_compact_bg" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="条件满足时走主路径，不满足时走另一条路径"
                android:textSize="12sp"
                android:textColor="#6a7682"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/edt_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="操作名称，例如: 条件二分路"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="条件变量名"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_condition_var"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="例如: retryCount"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="判断方式"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <AutoCompleteTextView
                android:id="@+id/edt_operator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="is_true / lt / lte / gt / gte / neq / eq"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tv_operand_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="比较值（一元运算可不填）"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/edt_operand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="例如: 5"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="条件满足路径"
                android:textSize="14sp"
                android:textColor="#3c9e5f"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <AutoCompleteTextView
                    android:id="@+id/edt_body_next"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="条件满足时跳转的节点"/>

                <TextView
                    android:id="@+id/btn_pick_body"
                    android:layout_width="58dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="选择"
                    android:textColor="#315dbf"
                    android:background="@drawable/item_operation_compact_bg"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="条件不满足路径"
                android:textSize="14sp"
                android:textColor="#B23B3B"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <AutoCompleteTextView
                    android:id="@+id/edt_exit_next"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="条件不满足时跳转的节点"/>

                <TextView
                    android:id="@+id/btn_pick_exit"
                    android:layout_width="58dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="选择"
                    android:textColor="#315dbf"
                    android:background="@drawable/item_operation_compact_bg"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="取消"
            android:textColor="#666666"
            android:background="@drawable/btn_cancel_bg"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="确认添加"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_edit_selector"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>

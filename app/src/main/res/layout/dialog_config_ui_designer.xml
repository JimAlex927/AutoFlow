<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/project_panel_shell_bg"
    android:fadeScrollbars="false"
    android:fillViewport="true"
    android:overScrollMode="always"
    android:scrollbarStyle="insideInset"
    android:scrollbars="vertical">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_config_ui_designer_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ConfigUI 设计"
        android:textColor="#243244"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="一个 UI 可包含多个页面；现在支持显式切页，设计区会优先给画布留出更宽空间。"
        android:textColor="#7B8794"
        android:textSize="11sp" />

    <EditText
        android:id="@+id/et_config_ui_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/item_operation_compact_bg"
        android:hint="UI 名称"
        android:inputType="text|textNoSuggestions"
        android:padding="10dp"
        android:textColor="#243244"
        android:textColorHint="#AABBCC"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_config_ui_prev_page"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="‹"
            android:textColor="#2F4F7C"
            android:textSize="18sp"
            android:textStyle="bold" />

        <AutoCompleteTextView
            android:id="@+id/actv_config_ui_page"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:completionThreshold="0"
            android:dropDownHeight="wrap_content"
            android:hint="选择页面"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textColor="#243244"
            android:textColorHint="#AABBCC"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_config_ui_next_page"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="›"
            android:textColor="#2F4F7C"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_config_ui_add_page"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="加页"
            android:textColor="#2F4F7C"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_config_ui_page_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="第 1 / 1 页"
        android:textColor="#7B8794"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_config_ui_rename_page"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="改页面名"
            android:textColor="#526273"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_config_ui_delete_page"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="删当前页"
            android:textColor="#F44336"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_config_ui_page_scale"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="缩放 100%"
            android:textColor="#2F4F7C"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.45"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="页面画布"
                android:textColor="#243244"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="默认按 100% 尺寸设计，减少无效留白；拖到哪里就放到哪里。"
                android:textColor="#7B8794"
                android:textSize="11sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/item_operation_compact_bg"
                android:minHeight="260dp"
                android:padding="8dp">

                <com.auto.master.configui.ConfigUiCanvasEditorView
                    android:id="@+id/view_config_ui_canvas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="172dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="组件仓库"
                android:textColor="#243244"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_config_ui_palette_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="长按拖进画布，也可以点一下快速加入当前页。"
                android:textColor="#7B8794"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_add_text_component"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:text="文本"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_number_component"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:text="数字"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_add_switch_component"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:text="开关"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_select_component"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:text="下拉"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_add_textarea_component"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:text="长文本"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_array_component"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:text="数组"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_add_title_component"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="标题 / 分组"
                android:textColor="#2F4F7C"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
            android:id="@+id/btn_preview_config_ui"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="预览"
            android:textColor="#2F4F7C"
            android:textSize="12sp"
            android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_config_ui_cancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="取消"
            android:textColor="#6A7682"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_config_ui_save"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="保存绑定"
            android:textColor="#2F4F7C"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
</ScrollView>

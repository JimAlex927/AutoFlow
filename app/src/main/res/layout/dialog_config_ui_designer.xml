<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/project_panel_shell_bg"
    android:fadeScrollbars="false"
    android:fillViewport="true"
    android:overScrollMode="always"
    android:scrollbarStyle="insideInset"
    android:scrollbars="vertical">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_config_ui_designer_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ConfigUI 设计"
        android:textColor="#243244"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="手机优先的设计面板：组件库收成快捷栏，把更多空间留给画布。点击可快速加入，长按可直接拖进画布。"
        android:textColor="#7B8794"
        android:textSize="11sp" />

    <EditText
        android:id="@+id/et_config_ui_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/item_operation_compact_bg"
        android:hint="UI 名称"
        android:inputType="text|textNoSuggestions"
        android:padding="10dp"
        android:textColor="#243244"
        android:textColorHint="#AABBCC"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <HorizontalScrollView
            android:id="@+id/scroll_config_ui_tabs"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:fadeScrollbars="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layout_config_ui_tabs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/btn_config_ui_add_page"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="+ 页面"
            android:textColor="#2F4F7C"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_config_ui_page_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="第 1 / 1 页"
        android:textColor="#7B8794"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_config_ui_rename_page"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="改页面名"
            android:textColor="#526273"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_config_ui_delete_page"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="删当前页"
            android:textColor="#F44336"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_config_ui_page_scale"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="缩放 100%"
            android:textColor="#2F4F7C"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_config_ui_edit_component"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="编辑已选组件"
            android:textColor="#2F4F7C"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_config_ui_move_component"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="移动已选组件"
            android:textColor="#2F4F7C"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_config_ui_selection_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="先点选一个组件，再编辑或移动；双指可直接缩放选中的组件。"
        android:textColor="#7B8794"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="组件快捷栏"
            android:textColor="#243244"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_config_ui_palette_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="点一下快速加入当前页。选中组件后，用顶部按钮移动；双指可缩放。"
            android:textColor="#7B8794"
            android:textSize="11sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fadeScrollbars="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_add_text_component"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="文本"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_number_component"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="数字"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_switch_component"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="开关"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_select_component"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="下拉"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_textarea_component"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:minWidth="82dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="长文本"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_array_component"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="数组"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_add_title_component"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/item_operation_compact_bg"
                    android:gravity="center"
                    android:minWidth="98dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="标题 / 分组"
                    android:textColor="#2F4F7C"
                    android:textSize="12sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="页面画布"
                android:textColor="#243244"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="默认按 100% 尺寸设计，减少无效留白；拖到哪里就放到哪里。"
                android:textColor="#7B8794"
                android:textSize="11sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/item_operation_compact_bg"
                android:minHeight="420dp"
                android:padding="8dp">

                <com.auto.master.configui.ConfigUiCanvasEditorView
                    android:id="@+id/view_config_ui_canvas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
            android:id="@+id/btn_preview_config_ui"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="预览"
            android:textColor="#2F4F7C"
            android:textSize="12sp"
            android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_config_ui_cancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="取消"
            android:textColor="#6A7682"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_config_ui_save"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="保存绑定"
            android:textColor="#2F4F7C"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
</ScrollView>

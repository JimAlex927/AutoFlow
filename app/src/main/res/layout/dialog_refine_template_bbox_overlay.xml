<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#33000000">

    <com.auto.master.auto.ColorPointPickerView
        android:id="@+id/template_refine_picker_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="template refine picker" />

    <LinearLayout
        android:id="@+id/template_refine_floating_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/panel_background"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="9dp"
        android:paddingEnd="10dp"
        android:paddingBottom="9dp">

        <TextView
            android:id="@+id/tv_template_refine_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="精选第1步：选择左上角"
            android:textColor="@color/colorOnSurface"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_template_refine_coord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="x=0, y=0"
            android:textColor="@color/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_template_refine_preview"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginTop="8dp"
            android:adjustViewBounds="true"
            android:background="#14FFFFFF"
            android:padding="2dp"
            android:scaleType="fitCenter"
            android:src="@android:color/transparent"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_template_refine_cancel"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/btn_cancel_bg"
                android:gravity="center"
                android:minWidth="56dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="取消"
                android:textColor="#33455C"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_template_refine_confirm"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/btn_edit_selector"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="下一步"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="1dp">

    <FrameLayout
        android:id="@+id/floating_ball_container"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/floating_ball_modern_bg"
        android:clickable="true"
        android:focusable="true"
        android:elevation="5dp">

        <ImageView
            android:id="@+id/floatingBall"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/logo_atom_dna"
            android:contentDescription="floating ball" />
    </FrameLayout>

    <TextView
        android:id="@+id/ball_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:maxWidth="132dp"
        android:paddingStart="7dp"
        android:paddingTop="3dp"
        android:paddingEnd="7dp"
        android:paddingBottom="3dp"
        android:background="@drawable/floating_ball_status_bg"
        android:text=""
        android:textSize="10sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:visibility="gone"
        android:ellipsize="end"
        android:maxLines="1"
        android:gravity="center" />

</LinearLayout>
